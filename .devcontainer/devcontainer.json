{
  "name": "Node.js",
  "image": "://microsoft.com",
  
  // Forward these ports automatically when the codespace starts
  "forwardPorts": [3000,5173],

  // Optional: Add labels and set default visibility for ports
  "portsAttributes": {
    "5173": {
      "label": "Frontend Server",
      "onAutoForward": "notify"
    },
    "3000": {
      "label": "Backend API",
      "onAutoForward": "silent"
    }
  }
}
